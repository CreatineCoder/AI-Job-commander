{
  "name": "applications",
  "primary_key_column": "id",
  "enable_rls": true,
  "visibility": "PUBLIC",
  "columns": [
    { "name": "company", "type": "TEXT", "required": true, "max_length": 240 },
    { "name": "role", "type": "TEXT", "required": true, "max_length": 240 },
    { "name": "source", "type": "TEXT", "max_length": 120 },
    { "name": "jd_file", "type": "FILE_PATH" },
    { "name": "jd_text", "type": "TEXT" },
    { "name": "resume_file", "type": "FILE_PATH" },
    { "name": "resume_id", "type": "UUID", "foreign_key": { "references": "resume_data.id" } },
    { "name": "must_have_skills", "type": "JSON" },
    { "name": "match_score", "type": "INTEGER" },
    { "name": "resume_gaps", "type": "TEXT" },
    { "name": "suggested_topics", "type": "JSON" },
    { "name": "email_subject", "type": "TEXT", "max_length": 240 },
    { "name": "draft_message", "type": "TEXT" },
    { "name": "cover_letter", "type": "TEXT" },
    { "name": "outreach_status", "type": "ENUM", "default": "none",
      "options": ["none", "drafted", "approved", "sent"] },
    { "name": "sent_at", "type": "DATETIME" },
    { "name": "status", "type": "ENUM", "required": true, "default": "applied",
      "options": ["applied", "screening", "interview", "offer", "rejected"] },
    { "name": "sub_status", "type": "TEXT", "max_length": 60 },
    { "name": "next_action", "type": "TEXT" },
    { "name": "todos", "type": "JSON" },
    { "name": "interview_prep", "type": "JSON" },
    { "name": "contact_name", "type": "TEXT", "max_length": 160 },
    { "name": "contact_email", "type": "TEXT", "max_length": 240 },
    { "name": "notes", "type": "TEXT" }
  ],
  "config": {}
}
